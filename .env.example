# Copie este arquivo para .env.local e preencha os valores.
# O .env.local NÃO vai para o git (cada dev cria o seu).

# === Firebase (Web) ===
# Pegue em: Firebase Console > Configurações do projeto > Geral > "Seus apps" > SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === EmailJS (envio dos e-mails de convite) ===
# Pegue no painel do EmailJS (https://dashboard.emailjs.com) ou peça ao responsável do projeto.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# === Firebase Admin (SERVIDOR — usado pela API de ativar/desativar acesso) ===
# Esta chave dá acesso TOTAL ao projeto e roda só no servidor (sem prefixo NEXT_PUBLIC_).
# - Em desenvolvimento local: deixe em branco — a API lê o serviceAccountKey.json da raiz.
# - Em produção (ex.: Vercel): cole AQUI o JSON inteiro da service account, em uma linha só.
# 🔒 Nunca faça commit desta chave nem a exponha no client.
FIREBASE_SERVICE_ACCOUNT=

# === Meta / Instagram (SERVIDOR — Graph API para métricas sociais) ===
# Passo a passo completo em src/lib/meta/README.md.
# 1) Crie um App (tipo Business) em https://developers.facebook.com e pegue App ID + App Secret.
# 2) META_SYSTEM_USER_TOKEN: token de um System User do Business Manager (recomendado —
#    acessa todas as contas atribuídas e pode ser configurado para não expirar).
# 🔒 Server-only (sem prefixo NEXT_PUBLIC_). Nunca faça commit nem exponha no client.
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
# Opcional — versão da Graph API (default v23.0).
META_GRAPH_VERSION=

# === Cron (SERVIDOR — protege a sincronização automática) ===
# Segredo que o Vercel Cron envia no header Authorization ao chamar a rota de
# sincronização. Gere um valor aleatório (ex.: `openssl rand -hex 32`).
CRON_SECRET=

# === Portal do artista (WhatsApp de solicitação de vínculo) ===
# Número (formato internacional, só dígitos) que recebe as solicitações de
# "Vincular redes sociais" via link wa.me. Ex.: 5575991094793 (55 = Brasil).
# É público (NEXT_PUBLIC_) — não use um número que precise ficar privado.
NEXT_PUBLIC_IMAGINE_WHATSAPP=
