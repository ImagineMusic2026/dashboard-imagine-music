# Copie este arquivo para .env.local e preencha os valores.
# O .env.local NÃO vai para o git (cada dev cria o seu).

# === Firebase (Web) ===
# Pegue em: Firebase Console > Configurações do projeto > Geral > "Seus apps" > SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === EmailJS (envio dos e-mails de convite) ===
# Pegue no painel do EmailJS (https://dashboard.emailjs.com) ou peça ao responsável do projeto.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# === Firebase Admin (SERVIDOR — usado pela API de ativar/desativar acesso) ===
# Esta chave dá acesso TOTAL ao projeto e roda só no servidor (sem prefixo NEXT_PUBLIC_).
# - Em desenvolvimento local: deixe em branco — a API lê o serviceAccountKey.json da raiz.
# - Em produção (ex.: Vercel): cole AQUI o JSON inteiro da service account, em uma linha só.
# 🔒 Nunca faça commit desta chave nem a exponha no client.
FIREBASE_SERVICE_ACCOUNT=
