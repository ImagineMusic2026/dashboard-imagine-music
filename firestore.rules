rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Autenticado, com perfil, e que NÃO esteja desativado.
    // (campo `ativo` ausente = tratado como ativo, para retrocompatibilidade)
    function isAtivo() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userData().get('ativo', true) != false;
    }

    function isAdmin() {
      return isAtivo() && userData().role == 'admin';
    }

    // Equipe Imagine (admin ou marketing) — enxerga o painel completo.
    function isStaff() {
      return isAtivo()
        && (userData().get('role', '') == 'admin' || userData().get('role', '') == 'marketing');
    }

    // Artista ativo cujo login está amarrado a ESTE slug (e só a ele).
    function isArtistaDe(slug) {
      return isAtivo()
        && userData().get('role', '') == 'artista'
        && userData().get('artistaSlug', '') == slug;
    }

    function convite(token) {
      return get(/databases/$(database)/documents/convites/$(token)).data;
    }

    // Perfis / membros do time
    match /users/{userId} {
      // O próprio usuário sempre lê o seu doc (pra descobrir se foi desativado).
      // Ler/listar os demais membros exige estar ativo.
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow list: if isStaff();

      // Admin gerencia membros diretamente, OU a própria pessoa cria seu doc
      // ao aceitar um convite válido (a role vem do convite — sem auto-promoção).
      allow create: if isAdmin()
        || (
          request.auth.uid == userId
          && request.resource.data.email == request.auth.token.email
          && exists(/databases/$(database)/documents/convites/$(request.resource.data.conviteToken))
          && convite(request.resource.data.conviteToken).status == 'pendente'
          && convite(request.resource.data.conviteToken).email == request.resource.data.email
          && convite(request.resource.data.conviteToken).role == request.resource.data.role
          && request.resource.data.get('artistaSlug', '')
               == convite(request.resource.data.conviteToken).get('artistaSlug', '')
        );

      allow update, delete: if isAdmin();
    }

    // Convites
    match /convites/{token} {
      // Leitura de UM convite por token (link secreto, UUID) é liberada;
      // listar todos é só admin.
      allow get: if true;
      allow list: if isAdmin();

      allow create: if isAdmin();

      // Admin gerencia; OU o convidado marca o próprio convite como aceito.
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.token.email == resource.data.email);

      allow delete: if isAdmin();
    }

    // Cadastro do artista (nome, redes, label): NÃO é sensível para a equipe.
    // Staff (admin/marketing) lê todo o roster; o artista lê SOMENTE o próprio. Escrita só servidor.
    match /artistas/{slug} {
      allow read: if isStaff() || isArtistaDe(slug);
      allow write: if false;
    }

    // Receita (SENSÍVEL): só admin lê. Marketing não vê. Escrita só servidor.
    match /receitas/{slug} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /importacoes/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Histórico do cadastro/roster de artistas (links de redes). Escrita só servidor.
    match /cadastros/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Métricas de redes sociais (Instagram via Meta, TikTok via Display API): NÃO
    // são sensíveis para a equipe. Staff lê tudo; o artista lê só o próprio slug.
    // Escrita só servidor (Admin SDK).
    match /metricas-sociais/{slug} {
      allow read: if isStaff() || isArtistaDe(slug);
      allow write: if false;
      match /historico/{dia} {
        allow read: if isStaff() || isArtistaDe(slug);
        allow write: if false;
      }
      match /historico-tiktok/{dia} {
        allow read: if isStaff() || isArtistaDe(slug);
        allow write: if false;
      }
      match /historico-youtube/{dia} {
        allow read: if isStaff() || isArtistaDe(slug);
        allow write: if false;
      }
      match /historico-health/{dia} {
        allow read: if isStaff() || isArtistaDe(slug);
        allow write: if false;
      }
    }

    // Tokens OAuth (SEGREDO: access/refresh token) do TikTok e do YouTube.
    // Ninguém lê/escreve pelo client — só o Admin SDK no servidor. (O catch-all
    // abaixo já negaria, mas explicitamos para deixar a intenção clara.)
    match /tiktok-tokens/{slug} {
      allow read, write: if false;
    }
    match /youtube-tokens/{slug} {
      allow read, write: if false;
    }

    // Status das integrações (ex.: integracoes/meta). Leitura só staff;
    // escrita só servidor.
    match /integracoes/{doc} {
      allow read: if isStaff();
      allow write: if false;
    }

    // Agenda (eventos: releases, shows, contratos, reuniões). Dado manual da
    // equipe — staff (admin/marketing) lê e escreve direto do client (CRUD do painel).
    match /agenda/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isStaff();
    }

    // Demais coleções ficam bloqueadas até serem modeladas.
    // (ao modelar dados reais, exija isAtivo() — e isAdmin() para escrita sensível)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
